generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccreditationCategory {
  NO_ACCREDITED
  ACCREDITED
}

enum BudgetRange {
  RANGE_0_50000
  RANGE_50001_100000
  RANGE_100001_250000
  RANGE_250001_500000
  RANGE_500001_1000000
  RANGE_1000001_PLUS
}

model Report {
  id             String             @id @default(uuid())
  title          String
  abstract       String // resumen corto para el listado
  summary        String // resumen largo para detalle
  thumbnail_url  String // miniatura en R2
  file_url       String // PDF en R2
  area           String // filtro principal
  tags           String[] // array de etiquetas
  accreditation  AccreditationCategory? // enum en vez de boolean
  editors        String? // max 500 chars
  organization   String? // max 255 chars
  budget_range   BudgetRange?
  country        String
  publish_year   Int
  created_at     DateTime           @default(now()) @db.Timestamptz

  @@index([area])
  @@index([country])
  @@index([accreditation])
  @@index([budget_range])
  @@index([created_at])
}

model User {
  id            String   @id @default(uuid())
  auth_user     String   @unique // ID del usuario en Supabase Auth
  email         String   @unique
  org_name      String
  entity_type   String
  newsletter    Boolean
  sroi_info     Boolean
  download_only Boolean
  created_at    DateTime @default(now()) @db.Timestamptz

  @@index([entity_type])
}